# MANIFEST.in
# Controls which non-Python files are included in the source distribution

include LICENSE
include README.md
include CHANGELOG.md
include CONTRIBUTING.md
include CITATION.cff
include requirements.txt
include pyproject.toml

# Include any config or schema files inside the package
recursive-include widennet *.json
recursive-include widennet *.yaml
recursive-include widennet *.yml

# Exclude unnecessary files
exclude .gitignore
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude * .DS_Store
exclude data/*
exclude models/*
exclude results/*
